# ----- BharatTrust AI environment -----
# Leave DATABASE_URL unset to use the bundled zero-config SQLite file.
# For Supabase / Postgres, use the connection string from your project:
#   DATABASE_URL=postgresql+psycopg://postgres:PASSWORD@db.<ref>.supabase.co:5432/postgres
# DATABASE_URL=

# Allowed frontend origin(s) for CORS (comma-separated). "*" for local dev.
FRONTEND_ORIGIN=*

# Optional: Mistral API key — the agents run fully offline without it.
# Set this only if you wire the optional LLM-narration hook in agents.
# MISTRAL_API_KEY=
